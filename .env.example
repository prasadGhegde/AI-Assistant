# Copy this file to .env and fill in values.

OPENAI_API_KEY=your-openai-api-key-here

# Text model fallback plus per-stage overrides.
OPENAI_MODEL=gpt-5.4-mini
OPENAI_SIGNAL_MODEL=gpt-5.4-mini
OPENAI_WRITER_MODEL=gpt-5.4

# Speech model and voice for the MP3 narration.
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=ryan
MORNING_BRIEFS_FORCE_RYAN=true
OPENAI_TTS_FALLBACK_VOICE=cedar
OPENAI_TTS_ALLOW_FALLBACK=true
OPENAI_TTS_INSTRUCTIONS="Use the Ryan system voice when available. Speak as a premium morning assistant: warm, crisp, composed, energetic without rushing, polished like a high-end British-leaning news presenter. Never imitate or reference any copyrighted character."
MORNING_BRIEFS_VOICE_EFFECT_ENABLED=true
MORNING_BRIEFS_VOICE_EFFECT_MODE=subtle_assistant
MORNING_BRIEFS_VOICE_EFFECT_DEFAULT_PRESET=jarvis_clean
MORNING_BRIEFS_VOICE_EFFECT_RENDER_ALL=true
MORNING_BRIEFS_VOICE_EFFECT_SAVE_WAVS=true
MORNING_BRIEFS_NARRATION_RECENT_LIMIT=5

# Personalization and weather.
MORNING_BRIEFS_USER_NAME=Prasad
MORNING_BRIEFS_WEATHER_LOCATION=Berlin
MORNING_BRIEFS_WEATHER_LAT=52.52
MORNING_BRIEFS_WEATHER_LON=13.405
MORNING_BRIEFS_WEATHER_TEMPERATURE_UNIT=celsius
MORNING_BRIEFS_WEATHER_WIND_UNIT=kmh

# Europe/Berlin matches your current Mac context. Change if needed.
MORNING_BRIEFS_TIMEZONE=Europe/Berlin

# Keep a strict recent-news bias.
MORNING_BRIEFS_LAST_HOURS=24
MORNING_BRIEFS_GOOD_NEWS_ONLY=true

# Optional tuning.
MORNING_BRIEFS_MAX_ITEMS_PER_SOURCE=10
MORNING_BRIEFS_FETCH_TIMEOUT=12
MORNING_BRIEFS_AUDIO_AUTOPLAY_COMMAND=afplay
MORNING_BRIEFS_AUDIO_DRIVER=browser
MORNING_BRIEFS_OPEN_BROWSER=true
MORNING_BRIEFS_BROWSER_APP="Google Chrome"
MORNING_BRIEFS_BROWSER_CLOSE_ON_END=true
MORNING_BRIEFS_BROWSER_AUTOPLAY_POLICY=true
MORNING_BRIEFS_BROWSER_FULLSCREEN=true
MORNING_BRIEFS_BROWSER_KIOSK=true
MORNING_BRIEFS_BROWSER_HIDE_FULLSCREEN_TOOLBAR=true
MORNING_BRIEFS_BROWSER_RESTORE_FULLSCREEN_TOOLBAR=true
MORNING_BRIEFS_CHROME_USER_DATA_DIR=/tmp/morning-briefs-chrome-profile
MORNING_BRIEFS_PRESENTATION_MODE=true
MORNING_BRIEFS_PRESENTATION_START_DELAY_SECONDS=1.8
MORNING_BRIEFS_DASHBOARD_HOST=127.0.0.1
MORNING_BRIEFS_DASHBOARD_PORT=8765
MORNING_BRIEFS_SERVE_DASHBOARD_FOR_RUNS=true
MORNING_BRIEFS_FOLLOWUP_TIMEOUT_SECONDS=10
MORNING_BRIEFS_MUSIC_ENABLED=true
MORNING_BRIEFS_MUSIC_VOLUME=0.24
MORNING_BRIEFS_MUSIC_DUCKING_ENABLED=true
MORNING_BRIEFS_BROWSER_MUSIC_ENABLED=true
MORNING_BRIEFS_MUSIC_SOURCE=/Users/prasadhegde/Documents/MorningBriefs/assets/audio/jarvis_proper_8min.wav
MORNING_BRIEFS_MUSIC_MAX_DURATION_SECONDS=380
MORNING_BRIEFS_FFMPEG_PATH=ffmpeg
