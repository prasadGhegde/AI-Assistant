# Copy this file to .env and fill in values.

OPENAI_API_KEY=your-openai-api-key-here

# Text model used for signal extraction and script writing.
OPENAI_MODEL=gpt-5-mini

# Speech model and voice for the MP3 narration.
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=coral

# Europe/Berlin matches your current Mac context. Change if needed.
MORNING_BRIEFS_TIMEZONE=Europe/Berlin

# Keep a strict recent-news bias.
MORNING_BRIEFS_LAST_HOURS=24

# Optional tuning.
MORNING_BRIEFS_MAX_ITEMS_PER_SOURCE=10
MORNING_BRIEFS_FETCH_TIMEOUT=12
MORNING_BRIEFS_AUDIO_AUTOPLAY_COMMAND=afplay
